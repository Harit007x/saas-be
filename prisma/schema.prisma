generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @map("_id") @default(auto()) @db.ObjectId
  name                String
  email               String   @unique
  password            String
  resetPasswordToken  String?
  resetPasswordExpire DateTime?
  createdAt           DateTime @default(now())
  refreshTokens       RefreshToken[]
  monitors            Monitor[]
}

model RefreshToken {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BlacklistedToken {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Monitor {
  id         String   @id @map("_id") @default(auto()) @db.ObjectId
  profileUrl String
  postUrl    String?
  profileName String?
  profileHeadline String?
  profileImage String?
  followersCount Int?
  connectionsCount Int?
  totalPosts Int?
  engagementRate Float?
  postsPerDay Float?
  engagementPerPost Float?
  uniqueEngagers Int?
  webhookUrl String?
  isActive   Boolean  @default(true)
  provider   String?
  lastRunAt  DateTime?
  lastSuccessAt DateTime?
  lastError  String?
  consecutiveFailures Int @default(0)
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  icpDefinition  String?  // The prompt for AI classification
  leads          Lead[]
  runs           MonitorRun[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Lead {
  id             String   @id @map("_id") @default(auto()) @db.ObjectId
  name           String
  externalId     String?
  profileId      String?
  linkedinUrl    String?
  jobTitle       String?
  company        String?
  engagementType String   // "LIKE", "COMMENT"
  eventHash      String
  postUrl        String?
  engagedAt      DateTime?
  seniority      String?
  function       String?
  region         String?
  city           String?
  country        String?
  companyWebsite String?
  companyIndustry String?
  companySize    String?
  companyHq      String?
  icpStatus      String?  // "MATCH", "NO_MATCH", "MAYBE"
  icpReasoning   String?
  rawPayload     Json?
  monitorId      String   @db.ObjectId
  monitor        Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([monitorId, eventHash])
  @@index([monitorId, createdAt])
}

model MonitorRun {
  id              String   @id @map("_id") @default(auto()) @db.ObjectId
  monitorId       String   @db.ObjectId
  monitor         Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  provider        String
  status          String   // "SUCCESS", "FAILED"
  startedAt       DateTime
  endedAt         DateTime
  fetchedCount    Int
  newCount        Int
  errorCode       String?
  errorMessage    String?
  rawRunId        String?
  rawMeta         Json?
  createdAt       DateTime @default(now())

  @@index([monitorId, createdAt])
}
